---
import MainLayout from '../../layouts/MainLayout.astro';
import CommentAdmin from '../../components/CommentAdmin';
---

<MainLayout title="Comment Administration">
  <div id="admin-content" style="display: none;">
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-4xl font-bold">Comment Administration</h1>
      <a
        href="/admin/security"
        class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg transition-colors"
      >
        Security Dashboard
      </a>
    </div>
    <CommentAdmin client:load />
  </div>

  <div id="loading" class="flex min-h-screen items-center justify-center">
    <div class="text-center">
      <h1 class="text-2xl font-bold mb-4">Checking access...</h1>
      <p id="status" class="text-gray-600">Please wait...</p>
    </div>
  </div>

  <script>
    async function checkAccess() {
      const updateStatus = (message: string) => {
        const statusElement = document.getElementById('status');
        if (statusElement) {
          statusElement.textContent = message;
        }
        console.log('Status:', message);
      };

      const showContent = (show: boolean) => {
        const loadingElement = document.getElementById('loading');
        const contentElement = document.getElementById('admin-content');

        if (loadingElement && contentElement) {
          loadingElement.style.display = show ? 'none' : 'flex';
          contentElement.style.display = show ? 'block' : 'none';
        }
      };

      try {
        const { getCurrentAdmin } = await import('../../utils/supabase');
        const { base } = await import('../../utils/constants');
        const { getValidSession, completeSignOut } = await import(
          '../../utils/auth-helpers'
        );

        // Check session and validate expiration
        updateStatus('Validating session...');

        const session = await getValidSession();

        if (!session) {
          updateStatus('No valid session found. Redirecting...');
          await completeSignOut();
          setTimeout(() => {
            window.location.href = base;
          }, 1000);
          return;
        }

        console.log('User ID:', session.user.id);
        console.log('User Email:', session.user.email);

        updateStatus('Verifying admin access...');

        try {
          const admin = await getCurrentAdmin();
          console.log('Admin result:', admin);

          if (!admin) {
            updateStatus('Not an admin user. Redirecting...');
            await completeSignOut();
            setTimeout(() => {
              window.location.href = base;
            }, 1000);
            return;
          }

          updateStatus('Access granted!');
          showContent(true);

          // Set up periodic session validation (every 1 hour)
          setInterval(async () => {
            const currentSession = await getValidSession();
            if (!currentSession) {
              console.log('Session expired, redirecting...');
              await completeSignOut();
              window.location.href = base;
            }
          }, 3600000); // 1 hour
        } catch (adminError) {
          console.error('getCurrentAdmin error:', adminError);
          updateStatus(
            'Error checking admin status: ' +
              (adminError instanceof Error
                ? adminError.message
                : 'Unknown error')
          );
          const { completeSignOut } = await import('../../utils/auth-helpers');
          await completeSignOut();
          setTimeout(() => {
            window.location.href = base;
          }, 3000);
        }
      } catch (error) {
        const { base } = await import('../../utils/constants');
        const { completeSignOut } = await import('../../utils/auth-helpers');
        const errorMessage =
          error instanceof Error ? error.message : 'Unknown error';
        console.error('Access check failed:', error);

        updateStatus(`Access check failed: ${errorMessage}`);
        await completeSignOut();
        setTimeout(() => {
          window.location.href = base;
        }, 2000);
      }
    }

    // Wait for page to be fully loaded before checking auth
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', checkAccess);
    } else {
      checkAccess();
    }
  </script>
</MainLayout>
